# PostgreSQL — used by the postgres container and the DATABASE_URL below
POSTGRES_DB=flowboard
POSTGRES_USER=flowboard_user
POSTGRES_PASSWORD=change_me_in_production

# Prisma connection string — consumed by api and worker services
DATABASE_URL=postgresql://flowboard_user:change_me_in_production@postgres:5432/flowboard

# Redis — consumed by api (rate limiting, queues) and worker (BullMQ)
REDIS_URL=redis://redis:6379

# JWT — must be a long random secret; never commit the real value
JWT_SECRET=change_me_use_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# Application
NODE_ENV=development
PORT=3000
